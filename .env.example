# Runtime
HISTODELIB_ENV=development
HISTODELIB_RUN_MODE=fixture
HISTODELIB_DATA_ROOT=data
HISTODELIB_OUTPUT_ROOT=outputs
HISTODELIB_CACHE_ROOT=.cache/histodelib

# LLM API
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=qwen3.5-flash
LLM_PROVIDER=openai_compatible

# VLM API
VLM_API_KEY=
VLM_BASE_URL=
VLM_MODEL=qwen3.5-flash
VLM_PROVIDER=openai_compatible

# Optional judge model
JUDGE_API_KEY=
JUDGE_BASE_URL=
JUDGE_MODEL=

# API behavior
API_TIMEOUT_SECONDS=120
API_MAX_RETRIES=5
API_MAX_CONCURRENCY=2

# Budget protection
API_ALLOW_PAID_CALLS=false
API_MAX_TOTAL_REQUESTS=20
API_MAX_TOTAL_TOKENS=50000
API_MAX_ESTIMATED_COST=5.00

# Logging
LOG_LEVEL=INFO
STORE_RAW_API_RESPONSES=false
